# Copy to backend/.env.local and set your Groq API key
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Optional override if you need a custom Groq-compatible endpoint
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Live suggest-missing caps (optional overrides)
# LLM_SENTENCES_PER_AI_BATCH=40
# LLM_SUGGEST_CONTEXT_CHARS=200
# LLM_SUGGEST_MIN_DELTA_CHARS=150
# LLM_SUGGEST_MAX_DELTA_CHARS=3000

# Live enrichment scheduling (optional overrides)
# LLM_ENRICHMENT_DEBOUNCE_SECONDS=3